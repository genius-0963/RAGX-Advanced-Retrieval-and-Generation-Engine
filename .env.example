# ==============================================================================
# RAGX — Environment Configuration
# Copy this file to .env and fill in your values
# ==============================================================================

# ── General ───────────────────────────────────────────────────────────────────
RAGX_ENV=development                    # development | staging | production
RAGX_DEBUG=true
RAGX_LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AI...
COHERE_API_KEY=...

# ── Embedding Configuration ──────────────────────────────────────────────────
RAGX_EMBEDDING_PROVIDER=sentence-transformer   # openai | bge | sentence-transformer
RAGX_EMBEDDING_MODEL=all-MiniLM-L6-v2          # Model name
RAGX_EMBEDDING_DIMENSION=384                    # Embedding vector dimension

# ── Vector Store ──────────────────────────────────────────────────────────────
RAGX_VECTORSTORE_TYPE=chroma            # chroma | faiss
RAGX_VECTORSTORE_PATH=./data/vectorstore
RAGX_CHROMA_COLLECTION=ragx_default

# ── Chunking ──────────────────────────────────────────────────────────────────
RAGX_CHUNK_SIZE=500
RAGX_CHUNK_OVERLAP=100
RAGX_CHUNKING_STRATEGY=recursive       # recursive | semantic

# ── Retrieval ─────────────────────────────────────────────────────────────────
RAGX_RETRIEVAL_TOP_K=5
RAGX_RETRIEVAL_STRATEGY=hybrid          # similarity | bm25 | hybrid
RAGX_RERANKER=cross-encoder             # cross-encoder | cohere | none
RAGX_RERANKER_TOP_N=5

# ── LLM Configuration ────────────────────────────────────────────────────────
RAGX_LLM_PROVIDER=openai               # openai | anthropic | gemini | ollama
RAGX_LLM_MODEL=gpt-4o                  # Model name
RAGX_LLM_TEMPERATURE=0.0
RAGX_LLM_MAX_TOKENS=2048
RAGX_LLM_STREAMING=true

# ── Ollama (Local LLM) ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── API Server ────────────────────────────────────────────────────────────────
RAGX_API_HOST=0.0.0.0
RAGX_API_PORT=8000
RAGX_API_WORKERS=4
RAGX_API_CORS_ORIGINS=["http://localhost:3000"]

# ── Data Paths ────────────────────────────────────────────────────────────────
RAGX_DATA_RAW_PATH=./data/raw
RAGX_DATA_PROCESSED_PATH=./data/processed
RAGX_DATA_LOGS_PATH=./data/logs

# ── Monitoring ────────────────────────────────────────────────────────────────
RAGX_METRICS_ENABLED=true
RAGX_METRICS_PORT=9090
